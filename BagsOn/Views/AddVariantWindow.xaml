<!-- ========================= -->
<!-- ADD VARIANT WINDOW -->
<!-- ========================= -->

<Window x:Class="BagsOn.Views.AddVariantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додавання варіанту"
        Height="769"
        Width="723"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6FC"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E35D6A"/>

        <!-- CARD -->

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Background" Value="White"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- TEXTBOX -->

        <Style TargetType="TextBox">

            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="2"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- COMBOBOX -->

        <Style TargetType="ComboBox">

            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>

        </Style>

        <!-- BUTTON -->

        <Style x:Key="ModernButtonStyle" TargetType="Button">

            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.92"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- SECONDARY -->

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>

        </Style>

        <!-- DANGER -->

        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>

        </Style>

    </Window.Resources>

    <Grid Margin="22">

        <Border Style="{StaticResource CardStyle}"
                Padding="28">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- HEADER -->

                    <Grid Margin="0 0 0 26">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock Text="Новий варіант"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>

                            <TextBlock Text="Додавання кольору, фото та залишків"
                                       Margin="0 6 0 0"
                                       Foreground="#6B7280"/>

                        </StackPanel>

                    </Grid>

                    <!-- MODEL -->

                    <TextBlock Text="Модель товару"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="ProductComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 16"/>

                    <!-- COLOR -->

                    <TextBlock Text="Колір"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="ColorComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 16"/>

                    <!-- PRICE -->

                    <TextBlock Text="Ціна"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <TextBox x:Name="PriceTextBox"
                             Margin="0 0 0 16"
                             PreviewTextInput="PriceTextBox_PreviewTextInput"
                             DataObject.Pasting="PriceTextBox_Pasting"/>

                    <!-- QUANTITY -->

                    <TextBlock Text="Кількість"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <Grid Margin="0 0 0 16">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="-"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="MinusQuantityButton_Click"/>

                        <TextBox x:Name="QuantityTextBox"
                                 Grid.Column="1"
                                 Margin="10 0"
                                 Text="1"
                                 TextAlignment="Center"
                                 PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                 DataObject.Pasting="IntegerTextBox_Pasting"/>

                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="PlusQuantityButton_Click"/>

                    </Grid>

                    <!-- DATE -->

                    <TextBlock Text="Дата надходження"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <DatePicker x:Name="ArrivalDatePicker"
                                Height="44"
                                Margin="0 0 0 18"/>

                    <!-- IMAGES -->

                    <Expander Header="Фото товару"
                              Margin="0 0 0 20"
                              Background="#FAFBFF"
                              BorderBrush="#E5E7EB"
                              BorderThickness="1"
                              Padding="10">

                        <StackPanel Margin="6">

                            <DockPanel Margin="0 0 0 10">

                                <TextBox x:Name="ImagesInfoTextBox"
                                         Height="44"
                                         IsReadOnly="True"
                                         Width="420"
                                         DockPanel.Dock="Left"/>

                                <Button Content="+"
                                        Width="44"
                                        Margin="10 0 0 0"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="ChooseImagesButton_Click"/>

                            </DockPanel>

                            <ListBox x:Name="ImagesListBox"
                                     Height="90"
                                     BorderThickness="0"
                                     Background="Transparent"/>

                            <Button Content="Видалити фото"
                                    Margin="0 12 0 0"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="RemoveSelectedImageButton_Click"/>

                        </StackPanel>

                    </Expander>

                    <!-- ACTIONS -->

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Скасувати"
                                Width="120"
                                Margin="0 0 12 0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CancelButton_Click"/>

                        <Button Content="Зберегти"
                                Width="140"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="SaveButton_Click"/>

                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Window>