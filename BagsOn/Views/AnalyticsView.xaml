<UserControl x:Class="BagsOn.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BagsOn.ViewModels"
             Background="#F3F6FC">

    <UserControl.DataContext>
        <vm:AnalyticsVM/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <!-- MAIN CARD -->

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0 0 0 18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SMALL STATISTIC CARD -->

        <Style x:Key="SmallCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0 0 14 12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WARNING CARD -->

        <Style x:Key="WarningCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SmallCardStyle}">
            <Setter Property="Background" Value="#FFF7ED"/>
            <Setter Property="BorderBrush" Value="#FDBA74"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- DANGER CARD -->

        <Style x:Key="DangerCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource SmallCardStyle}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- BUTTONS -->

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5B8DEF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16 0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
        </Style>

        <!-- INPUTS -->

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- BEAUTIFUL TABS -->

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">

                        <Border x:Name="TabBorder"
                        MinWidth="150"
                        Height="42"
                        Background="#F3F4F6"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18 0">

                            <ContentPresenter ContentSource="Header"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      RecognizesAccessKey="True"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                Property="Background"
                                Value="#EEF2FF"/>

                                <Setter TargetName="TabBorder"
                                Property="BorderBrush"
                                Value="#C7D2FE"/>

                                <Setter Property="Foreground"
                                Value="#4F46E5"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder"
                                Property="Background"
                                Value="#5B8DEF"/>

                                <Setter TargetName="TabBorder"
                                Property="BorderBrush"
                                Value="#5B8DEF"/>

                                <Setter Property="Foreground"
                                Value="White"/>

                                <Setter TargetName="TabBorder"
                                Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID -->

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- LOW STOCK ROW -->

        <Style x:Key="LowStockRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Background" Value="White"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="Мало">
                    <Setter Property="Background" Value="#FFFBEB"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- LOW STOCK BADGE -->

        <Style x:Key="StockWarningBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8 3"/>
            <Setter Property="Background" Value="#FEF3C7"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->


            <!-- PERIOD FILTER -->

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0 0 14 0">

                        <TextBlock Text="Дата від"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0 0 0 6"/>

                        <DatePicker SelectedDate="{Binding DateFrom}"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0 0 14 0">

                        <TextBlock Text="Дата до"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0 0 0 6"/>

                        <DatePicker SelectedDate="{Binding DateTo}"/>

                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Застосувати"
                            Width="125"
                            Style="{StaticResource ModernButtonStyle}"
                            VerticalAlignment="Bottom"
                            Click="ApplyPeriodButton_Click"/>

                    <Button Grid.Column="3"
                            Content="Сьогодні"
                            Width="105"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Click="TodayButton_Click"/>

                    <Button Grid.Column="4"
                            Content="7 днів"
                            Width="95"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Click="Last7DaysButton_Click"/>

                </Grid>

            </Border>

            <!-- TABS -->

            <TabControl Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0">

                <!-- TAB 1: OVERVIEW -->

                <TabItem Header="Огляд">

                    <Grid Margin="0 16 0 0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- OVERVIEW SUMMARY -->

                        <Expander Grid.Row="0"
                                  Header="Показники аналітики"
                                  IsExpanded="False"
                                  Margin="0 0 0 18"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontSize="15"
                                  FontWeight="SemiBold"
                                  Foreground="#111827">

                            <UniformGrid Columns="4"
                                         Margin="0 14 0 0">

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Замовлень"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.TotalOrders}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Дохід"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.Revenue, StringFormat={}{0:N2} грн}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#15803D"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Середній чек"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.AverageCheck, StringFormat={}{0:N2} грн}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#4F46E5"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Виконані"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.CompletedOrders}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#15803D"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Скасовані"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.CancelledOrders}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#B91C1C"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource WarningCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Закінчуються"
                                                   FontSize="12"
                                                   Foreground="#92400E"/>
                                        <TextBlock Text="{Binding Summary.LowStockCount}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#92400E"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource DangerCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Немає в наявності"
                                                   FontSize="12"
                                                   Foreground="#B91C1C"/>
                                        <TextBlock Text="{Binding Summary.OutOfStockCount}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#B91C1C"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="З резервом"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding Summary.ReservedPositionsCount}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#6D28D9"/>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>

                        </Expander>

                        <!-- OVERVIEW TABLES -->

                        <Grid Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <!-- TOP PRODUCTS -->

                            <Border Grid.Column="0"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0 0 9 0">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Топ товарів за продажами"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0 0 0 14"/>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding TopProducts}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              MinHeight="280"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="Модель"
                                                                Binding="{Binding ModelName}"
                                                                Width="*"/>

                                            <DataGridTextColumn Header="Бренд"
                                                                Binding="{Binding BrandName}"
                                                                Width="110"/>

                                            <DataGridTextColumn Header="Продано"
                                                                Binding="{Binding SoldQuantity}"
                                                                Width="85"/>

                                            <DataGridTextColumn Header="Дохід"
                                                                Binding="{Binding Revenue, StringFormat={}{0:N2} грн}"
                                                                Width="120"/>

                                        </DataGrid.Columns>

                                    </DataGrid>

                                </Grid>

                            </Border>

                            <!-- REPLENISHMENT -->

                            <Border Grid.Column="1"
                                    Style="{StaticResource CardStyle}"
                                    Margin="9 0 0 0">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Потрібно поповнити"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0 0 0 14"/>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding ReplenishmentItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              MinHeight="280"
                                              RowStyle="{StaticResource LowStockRowStyle}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">

                                        <DataGrid.Columns>

                                            <DataGridTextColumn Header="Модель"
                                                                Binding="{Binding ModelName}"
                                                                Width="*"/>

                                            <DataGridTextColumn Header="Колір"
                                                                Binding="{Binding ColorName}"
                                                                Width="90"/>

                                            <DataGridTextColumn Header="Доступно"
                                                                Binding="{Binding AvailableQuantity}"
                                                                Width="75"/>

                                            <DataGridTextColumn Header="Мін."
                                                                Binding="{Binding MinQuantity}"
                                                                Width="60"/>

                                            <DataGridTextColumn Header="Докупити"
                                                                Binding="{Binding QuantityToBuy}"
                                                                Width="80"/>

                                            <DataGridTemplateColumn Header="Статус"
                                                                    Width="115">

                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>

                                                        <Border Style="{StaticResource StockWarningBadgeStyle}">
                                                            <TextBlock Text="{Binding StockStatus}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#92400E"
                                                                       HorizontalAlignment="Center"/>
                                                        </Border>

                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>

                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>

                                    </DataGrid>

                                </Grid>

                            </Border>

                        </Grid>

                    </Grid>

                </TabItem>

                <!-- TAB 2: STOCK MOVEMENTS -->

                <TabItem Header="Рух товарів">

                    <Grid Margin="0 16 0 0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- MOVEMENT SUMMARY -->

                        <Expander Grid.Row="0"
                                  Header="Показники руху товарів"
                                  IsExpanded="False"
                                  Margin="0 0 0 18"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontSize="15"
                                  FontWeight="SemiBold"
                                  Foreground="#111827">

                            <UniformGrid Columns="4"
                                         Margin="0 14 0 0">

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Надходження"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding IncomingQuantity}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#15803D"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Списання"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding WriteOffQuantity}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#B91C1C"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Продаж"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding SalesQuantity}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#4F46E5"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SmallCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Повернення"
                                                   FontSize="12"
                                                   Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding ReturnQuantity}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#6D28D9"/>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>

                        </Expander>

                        <!-- FILTERS AND EXPORT -->

                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <!-- SEARCH -->

                                <StackPanel Grid.Column="0"
                                            Margin="0 0 14 0">

                                    <TextBlock Text="Пошук по моделі, бренду, кольору або коментарю"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 6"/>

                                    <TextBox Text="{Binding MovementSearchText, UpdateSourceTrigger=PropertyChanged}"/>

                                </StackPanel>

                                <!-- VIEW FILTER -->

                                <StackPanel Grid.Column="1"
                                            Margin="0 0 14 0">

                                    <TextBlock Text="Тип руху в таблиці"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 6"/>

                                    <ComboBox ItemsSource="{Binding MovementTypes}"
                                              SelectedItem="{Binding SelectedMovementType}"/>

                                </StackPanel>

                                <!-- EXPORT FILTER -->

                                <StackPanel Grid.Column="2">

                                    <TextBlock Text="Експорт за типом руху"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 8"/>

                                    <WrapPanel Margin="0 0 0 10">

                                        <CheckBox Content="Всі"
                                                  IsChecked="{Binding ExportAllMovementTypes}"
                                                  Margin="0 0 14 8"/>

                                        <CheckBox Content="Надходження"
                                                  IsChecked="{Binding ExportIncoming}"
                                                  Margin="0 0 14 8"/>

                                        <CheckBox Content="Списання"
                                                  IsChecked="{Binding ExportWriteOff}"
                                                  Margin="0 0 14 8"/>

                                        <CheckBox Content="Продаж"
                                                  IsChecked="{Binding ExportSales}"
                                                  Margin="0 0 14 8"/>

                                        <CheckBox Content="Повернення"
                                                  IsChecked="{Binding ExportReturns}"
                                                  Margin="0 0 14 8"/>

                                        <CheckBox Content="Коригування"
                                                  IsChecked="{Binding ExportAdjustments}"
                                                  Margin="0 0 14 8"/>

                                    </WrapPanel>

                                    <StackPanel Orientation="Horizontal">

                                        <Button Content="Excel"
                                                Width="90"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ExportMovementsExcelButton_Click"/>

                                        <Button Content="PDF"
                                                Width="90"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="ExportMovementsPdfButton_Click"/>

                                    </StackPanel>

                                </StackPanel>

                            </Grid>

                        </Border>

                        <!-- MOVEMENT TABLE -->

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                VerticalAlignment="Stretch">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Перегляд руху товарів"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#111827"
                                           Margin="0 0 0 14"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding StockMovementsView}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          RowHeaderWidth="0"
                                          MinHeight="320"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                                    <DataGrid.Columns>

                                        <DataGridTextColumn Header="Дата руху"
                                                            Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                            Width="135"/>

                                        <DataGridTextColumn Header="Модель"
                                                            Binding="{Binding ModelName}"
                                                            Width="*"/>

                                        <DataGridTextColumn Header="Бренд"
                                                            Binding="{Binding BrandName}"
                                                            Width="100"/>

                                        <DataGridTextColumn Header="Колір"
                                                            Binding="{Binding ColorName}"
                                                            Width="90"/>

                                        <DataGridTextColumn Header="Тип руху"
                                                            Binding="{Binding MovementType}"
                                                            Width="110"/>

                                        <DataGridTextColumn Header="Кількість"
                                                            Binding="{Binding QuantityChangeText}"
                                                            Width="85"/>

                                        <DataGridTextColumn Header="Було"
                                                            Binding="{Binding QuantityBefore}"
                                                            Width="65"/>

                                        <DataGridTextColumn Header="Стало"
                                                            Binding="{Binding QuantityAfter}"
                                                            Width="65"/>

                                        <DataGridTextColumn Header="Останній рух"
                                                            Binding="{Binding LastMovementText}"
                                                            Width="105"/>

                                        <DataGridTextColumn Header="Коментар"
                                                            Binding="{Binding Comment}"
                                                            Width="150"/>

                                        <DataGridTemplateColumn Header="Історія"
                                                                Width="95">

                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>

                                                    <Button Content="Історія"
                                                            Tag="{Binding}"
                                                            Height="32"
                                                            Width="76"
                                                            Background="#EEF2FF"
                                                            Foreground="#4F46E5"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Click="OpenModelMovementHistoryButton_Click"/>

                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>

                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>

                                </DataGrid>

                            </Grid>

                        </Border>

                    </Grid>

                </TabItem>

                <!-- TAB 3: REPORTS -->

                <TabItem Header="Звіти">

                    <Grid Margin="0 16 0 0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- REPORT SETTINGS -->

                        <Border Grid.Row="0"
                                Style="{StaticResource CardStyle}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0 0 14 0">

                                    <TextBlock Text="Тип звіту"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 6"/>

                                    <ComboBox ItemsSource="{Binding ReportTypes}"
                                              SelectedItem="{Binding SelectedReportType}"
                                              DisplayMemberPath="Name"/>

                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="0 0 14 0">

                                    <TextBlock Text="Дата від"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 6"/>

                                    <DatePicker SelectedDate="{Binding DateFrom}"/>

                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Margin="0 0 14 0">

                                    <TextBlock Text="Дата до"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               Margin="0 0 0 6"/>

                                    <DatePicker SelectedDate="{Binding DateTo}"/>

                                </StackPanel>

                                <Button Grid.Column="3"
                                        Content="Сформувати"
                                        Width="130"
                                        Style="{StaticResource ModernButtonStyle}"
                                        VerticalAlignment="Bottom"
                                        Click="GenerateReportButton_Click"/>

                                <Button Grid.Column="4"
                                        Content="Друк"
                                        Width="90"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        VerticalAlignment="Bottom"
                                        Click="PrintReportButton_Click"/>

                                <Button Grid.Column="5"
                                        Content="PDF"
                                        Width="90"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        VerticalAlignment="Bottom"
                                        Click="ExportReportPdfButton_Click"/>

                            </Grid>

                        </Border>

                        <!-- REPORT PREVIEW -->

                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding ReportTitle}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#111827"
                                           Margin="0 0 0 6"/>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding ReportStatusText}"
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           Margin="0 0 0 14"/>

                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding ReportView}"
                                          AutoGenerateColumns="True"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          RowHeaderWidth="0"
                                          MinHeight="360"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                            </Grid>

                        </Border>

                    </Grid>

                </TabItem>

            </TabControl>

        </Grid>

    </ScrollViewer>

</UserControl>