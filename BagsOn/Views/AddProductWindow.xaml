<Window x:Class="BagsOn.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додавання товару"
        Height="930"
        Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6FC"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E35D6A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>

        <!-- CARD -->

        <Style x:Key="CardStyle" TargetType="Border">

            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="28"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- TEXTBOX -->

        <Style TargetType="TextBox">

            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="TextBox">

                        <Border CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="2"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- COMBOBOX -->

        <Style TargetType="ComboBox">

            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>

        </Style>

        <!-- BUTTON -->

        <Style x:Key="ModernButtonStyle" TargetType="Button">

            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.92"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- SECONDARY BUTTON -->

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>

        </Style>

        <!-- DANGER BUTTON -->

        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>

        </Style>

        <!-- EXPANDER -->

        <Style TargetType="Expander">

            <Setter Property="Background" Value="#FAFBFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>

        </Style>

    </Window.Resources>

    <Grid Margin="24">

        <Border Style="{StaticResource CardStyle}"
                Padding="30">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- HEADER -->

                    <Grid Margin="0 0 0 28">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock Text="Новий товар"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>

                            <TextBlock Text="Створення моделі, кольору та складських залишків"
                                       Margin="0 6 0 0"
                                       Foreground="#6B7280"/>

                        </StackPanel>

                    </Grid>

                    <!-- MODEL -->

                    <TextBlock Text="Назва моделі"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <TextBox x:Name="ModelNameTextBox"
                             Margin="0 0 0 18"/>

                    <!-- SEGMENT -->

                    <TextBlock Text="Сегмент бренду"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="SegmentComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 18"
                              SelectionChanged="SegmentComboBox_SelectionChanged"/>

                    <!-- BRAND -->

                    <TextBlock Text="Бренд"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <Grid Margin="0 0 0 18">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="BrandComboBox"
                                  Grid.Column="0"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <Button Grid.Column="1"
                                Content="+"
                                Margin="10 0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="AddBrandButton_Click"/>

                        <Button Grid.Column="2"
                                Content="Без бренду"
                                Margin="10 0 0 0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="NoBrandButton_Click"/>

                    </Grid>

                    <!-- TYPE -->

                    <TextBlock Text="Тип товару"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="TypeComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 18"/>

                    <!-- CATEGORIES -->

                    <Expander x:Name="CategoriesExpander"
                              Header="Категорії товару"
                              Margin="0 0 0 18">

                        <StackPanel Margin="8">

                            <TextBlock x:Name="CategoriesSummaryTextBlock"
                                       Text="Оберіть одну або декілька категорій"
                                       Foreground="#6B7280"
                                       Margin="0 0 0 10"/>

                            <ListBox x:Name="CategoryListBox"
                                     Height="140"
                                     SelectionMode="Multiple"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="CategoryListBox_SelectionChanged">

                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <CheckBox Content="{Binding Name}"
                                                  Margin="6 5"
                                                  FontSize="14"
                                                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                                                      Path=IsSelected,
                                                                      Mode=TwoWay}"/>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                        </StackPanel>

                    </Expander>

                    <!-- MATERIAL -->

                    <TextBlock Text="Матеріал"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="MaterialComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 18"/>

                    <!-- COLOR -->

                    <TextBlock Text="Колір варіанту"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <ComboBox x:Name="ColorComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Margin="0 0 0 18"/>

                    <!-- PRICE -->

                    <TextBlock Text="Ціна"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <TextBox x:Name="PriceTextBox"
                             Margin="0 0 0 18"
                             PreviewTextInput="PriceTextBox_PreviewTextInput"
                             DataObject.Pasting="PriceTextBox_Pasting"/>

                    <!-- QUANTITY -->

                    <TextBlock Text="Кількість"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <Grid Margin="0 0 0 18">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="-"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="MinusQuantityButton_Click"/>

                        <TextBox x:Name="QuantityTextBox"
                                 Grid.Column="1"
                                 Margin="10 0"
                                 Text="1"
                                 TextAlignment="Center"
                                 PreviewTextInput="IntegerTextBox_PreviewTextInput"
                                 DataObject.Pasting="IntegerTextBox_Pasting"/>

                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="PlusQuantityButton_Click"/>

                    </Grid>

                    <!-- DATE -->

                    <TextBlock Text="Дата надходження"
                               FontWeight="SemiBold"
                               Margin="0 0 0 6"/>

                    <DatePicker x:Name="ArrivalDatePicker"
                                Height="44"
                                Margin="0 0 0 20"/>

                    <!-- IMAGES -->

                    <Expander Header="Фото для цього кольору"
                              Margin="0 0 0 22">

                        <StackPanel Margin="8">

                            <DockPanel Margin="0 0 0 10">

                                <TextBox x:Name="ImagesInfoTextBox"
                                         Height="44"
                                         Width="470"
                                         IsReadOnly="True"
                                         DockPanel.Dock="Left"/>

                                <Button Content="+"
                                        Width="44"
                                        Margin="10 0 0 0"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="ChooseImagesButton_Click"/>

                            </DockPanel>

                            <ListBox x:Name="ImagesListBox"
                                     Height="90"
                                     BorderThickness="0"
                                     Background="Transparent"/>

                            <Button Content="Видалити фото"
                                    Margin="0 12 0 0"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Click="RemoveSelectedImageButton_Click"/>

                        </StackPanel>

                    </Expander>

                    <!-- ACTIONS -->

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Скасувати"
                                Width="120"
                                Margin="0 0 12 0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CancelButton_Click"/>

                        <Button Content="Створити товар"
                                Width="170"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="SaveButton_Click"/>

                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>

</Window>