<UserControl x:Class="BagsOn.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BagsOn.ViewModels"
             xmlns:converters="clr-namespace:BagsOn.Converters"
             Background="#F3F6FC">

    <UserControl.DataContext>
        <vm:StockVM/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E35D6A"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0 0 0 18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0 0 14 0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16 0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
        </Style>

        <Style x:Key="IconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0 0 7 0"/>
        </Style>

        <Style x:Key="DangerIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="#FDECEF"/>
            <Setter Property="Foreground" Value="#E35D6A"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- STOCK STATUS BADGE -->

        <Style x:Key="StockStatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="8 3"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F3F4F6"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="В наявності">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Мало">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Є резерв">
                    <Setter Property="Background" Value="#EDE9FE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StockStatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#374151"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="В наявності">
                    <Setter Property="Foreground" Value="#15803D"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Мало">
                    <Setter Property="Foreground" Value="#92400E"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Foreground" Value="#B91C1C"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Є резерв">
                    <Setter Property="Foreground" Value="#6D28D9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="8 3"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Background" Value="#FEF3C7"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarning}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#92400E"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Foreground" Value="#B91C1C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StockRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="76"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="Transparent"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding StockStatus}" Value="Мало">
                    <Setter Property="Background" Value="#FFFBEB"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding StockStatus}" Value="Немає">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->



        <!-- STATISTICS -->

        <Grid Grid.Row="1"
              Margin="0 0 0 18">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SmallCardStyle}">
                <StackPanel>
                    <TextBlock Text="Позицій"
                               FontSize="12"
                               Foreground="#6B7280"/>
                    <TextBlock Text="{Binding TotalPositionsCount}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SmallCardStyle}">
                <StackPanel>
                    <TextBlock Text="Закінчуються"
                               FontSize="12"
                               Foreground="#6B7280"/>
                    <TextBlock Text="{Binding LowStockCount}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#92400E"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SmallCardStyle}">
                <StackPanel>
                    <TextBlock Text="Немає"
                               FontSize="12"
                               Foreground="#6B7280"/>
                    <TextBlock Text="{Binding OutOfStockCount}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#B91C1C"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Style="{StaticResource SmallCardStyle}">
                <StackPanel>
                    <TextBlock Text="З резервом"
                               FontSize="12"
                               Foreground="#6B7280"/>
                    <TextBlock Text="{Binding ReservedCount}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#6D28D9"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource SmallCardStyle}"
                    Margin="0">
                <StackPanel>
                    <TextBlock Text="Вартість складу"
                               FontSize="12"
                               Foreground="#6B7280"/>
                    <TextBlock Text="{Binding TotalStockValue, StringFormat={}{0:N2} грн}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#15803D"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- STOCK TABLE CARD -->

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                VerticalAlignment="Stretch">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FILTERS -->

                <Border Grid.Row="0"
                        Background="#F9FAFB"
                        CornerRadius="18"
                        Padding="16"
                        Margin="0 0 0 14">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- SEARCH -->

                        <StackPanel Grid.Column="0"
                Margin="0 0 14 0">

                            <TextBlock Text="Пошук"
                   Foreground="#6B7280"
                   FontSize="12"
                   Margin="0 0 0 6"/>

                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <!-- STOCK STATUS -->

                        <StackPanel Grid.Column="1"
                Margin="0 0 14 0">

                            <TextBlock Text="Статус складу"
                   Foreground="#6B7280"
                   FontSize="12"
                   Margin="0 0 0 6"/>

                            <ComboBox ItemsSource="{Binding StockStatuses}"
                  SelectedItem="{Binding SelectedStockStatus}"/>

                        </StackPanel>

                        <!-- ACTION BUTTONS -->

                        <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Bottom">

                            <Button Content="Очистити"
                Width="100"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="ClearFiltersButton_Click"/>

                            <Button Content="Excel"
                Width="80"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="ExportExcelButton_Click"/>

                            <Button Content="PDF"
                Width="80"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="ExportPdfButton_Click"/>

                            <Button Content="Друк"
                Width="80"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="PrintButton_Click"/>


                        </StackPanel>

                    </Grid>

                </Border>

                <!-- TABLE -->

                <DataGrid Grid.Row="1"
                          x:Name="StockDataGrid"
                          ItemsSource="{Binding StockItemsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          RowStyle="{StaticResource StockRowStyle}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          MinHeight="380"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Фото"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="58"
                                            Height="58"
                                            Background="#F3F4F6"
                                            CornerRadius="14"
                                            ClipToBounds="True">

                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                               Stretch="UniformToFill"/>

                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Модель"
                                            Binding="{Binding ModelName}"
                                            Width="170"/>

                        <DataGridTextColumn Header="Бренд"
                                            Binding="{Binding BrandName}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Тип"
                                            Binding="{Binding TypeName}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Категорії"
                                            Binding="{Binding CategoryName}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Колір"
                                            Binding="{Binding ColorName}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Ціна"
                                            Binding="{Binding Price, StringFormat={}{0:N2} грн}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Всього"
                                            Binding="{Binding TotalQuantity}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Резерв"
                                            Binding="{Binding ReservedQuantity}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Доступно"
                                            Binding="{Binding AvailableQuantity}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Мін."
                                            Binding="{Binding MinQuantity}"
                                            Width="70"/>

                        <DataGridTemplateColumn Header="Статус"
                                                Width="125">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StockStatusBadgeBorderStyle}">
                                        <TextBlock Text="{Binding StockStatus}"
                                                   Style="{StaticResource StockStatusBadgeTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Увага"
                                                Width="155">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WarningBadgeBorderStyle}">
                                        <TextBlock Text="{Binding StockWarning}"
                                                   Style="{StaticResource WarningBadgeTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Місце"
                                            Binding="{Binding Location}"
                                            Width="100"/>

                        <DataGridTemplateColumn Header="Дії"
                                                Width="205">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <Button Content="&#xE890;"
                                                ToolTip="Переглянути рух товару"
                                                Tag="{Binding}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Click="ViewMovementsButton_Click"/>

                                        <Button Content="+"
                                                ToolTip="Додати надходження"
                                                Tag="{Binding}"
                                                FontFamily="Segoe UI"
                                                FontSize="18"
                                                Style="{StaticResource IconButtonStyle}"
                                                Click="AddIncomingButton_Click"/>

                                        <Button Content="&#xE74D;"
                                                ToolTip="Списати товар"
                                                Tag="{Binding}"
                                                Style="{StaticResource DangerIconButtonStyle}"
                                                Click="WriteOffButton_Click"/>
                                        <Button Content="&#xE713;"
        ToolTip="Коригувати залишок після інвентаризації"
        Tag="{Binding}"
        Style="{StaticResource IconButtonStyle}"
        Click="AdjustStockButton_Click"/>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>
</UserControl>