<Window x:Class="BagsOn.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перегляд фото"
        Height="720"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F172A"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
        <SolidColorBrush x:Key="TextBrush" Color="White"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8"/>

        <!-- BUTTON -->

        <Style x:Key="NavigationButtonStyle" TargetType="Button">

            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#334155"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ICON BUTTON -->

        <Style x:Key="CircleButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavigationButtonStyle}">

            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#1E293B"/>

        </Style>

    </Window.Resources>

    <Grid Margin="26">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Grid Margin="0 0 0 22">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock x:Name="TitleTextBlock"
                           Text="Фото товару"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Перегляд зображень товару"
                           Margin="0 6 0 0"
                           FontSize="14"
                           Foreground="#94A3B8"/>

            </StackPanel>

        </Grid>

        <!-- IMAGE CONTAINER -->

        <Border Grid.Row="1"
                Background="#111827"
                CornerRadius="28"
                Padding="18"
                BorderBrush="#1E293B"
                BorderThickness="1">

            <Border.Effect>

                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Opacity="0.25"/>

            </Border.Effect>

            <Grid>

                <!-- IMAGE -->

                <Image x:Name="ProductImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- LEFT BUTTON -->

                <Button Content="←"
                        Width="54"
                        Height="54"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="12"
                        Style="{StaticResource CircleButtonStyle}"
                        Click="PreviousButton_Click"/>

                <!-- RIGHT BUTTON -->

                <Button Content="→"
                        Width="54"
                        Height="54"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="12"
                        Style="{StaticResource CircleButtonStyle}"
                        Click="NextButton_Click"/>

            </Grid>

        </Border>

        <!-- FOOTER -->

        <Grid Grid.Row="2"
              Margin="0 22 0 0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- BACK -->

            <Button Grid.Column="0"
                    Content="← Попереднє"
                    Style="{StaticResource NavigationButtonStyle}"
                    Click="PreviousButton_Click"/>

            <!-- COUNTER -->

            <Border Grid.Column="1"
                    Background="#111827"
                    HorizontalAlignment="Center"
                    Padding="22 12"
                    CornerRadius="16">

                <TextBlock x:Name="CounterTextBlock"
                           Text="0 / 0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Border>

            <!-- NEXT -->

            <Button Grid.Column="2"
                    Content="Наступне →"
                    Style="{StaticResource NavigationButtonStyle}"
                    Click="NextButton_Click"/>

        </Grid>

    </Grid>

</Window>