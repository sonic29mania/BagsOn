<UserControl x:Class="BagsOn.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BagsOn.ViewModels"
             xmlns:converters="clr-namespace:BagsOn.Converters"
             Background="#F3F6FC">

    <UserControl.DataContext>
        <vm:ProductsVM/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <!-- COLORS -->

        <SolidColorBrush x:Key="PrimaryBrush" Color="#5B8DEF"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#4A78E0"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E35D6A"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F6FC"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>

        <!-- MAIN CARD -->

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0 0 0 18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRODUCT CARD -->

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Width" Value="285"/>
            <Setter Property="MinHeight" Value="445"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0 0 18 18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRODUCT IMAGE -->

        <Style x:Key="ProductImageBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="170"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Margin" Value="0 0 0 14"/>
        </Style>

        <!-- PRODUCT INFO LABEL -->

        <Style x:Key="ProductInfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0 0 0 2"/>
        </Style>

        <!-- PRODUCT INFO VALUE -->

        <Style x:Key="ProductInfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- QUANTITY BADGE -->

        <Style x:Key="QuantityBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="Background" Value="#DCFCE7"/>
        </Style>

        <Style x:Key="QuantityBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#15803D"/>
        </Style>

        <!-- TABLE ACTION ICON BUTTON -->

        <Style x:Key="TableIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin" Value="0 0 7 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94"
                                                        ScaleY="0.94"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TABLE EDIT ICON -->

        <Style x:Key="TableEditButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TableIconButtonStyle}">

            <Setter Property="Background" Value="#F3E8FF"/>
            <Setter Property="Foreground" Value="#7C3AED"/>

        </Style>

        <!-- TABLE DELETE ICON -->

        <Style x:Key="TableDeleteButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TableIconButtonStyle}">

            <Setter Property="Background" Value="#FDECEF"/>
            <Setter Property="Foreground" Value="#E35D6A"/>

        </Style>

        <!-- TABLE VARIANT ICON -->

        <Style x:Key="TableVariantButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TableIconButtonStyle}">

            <Setter Property="Background" Value="#E0F2FE"/>
            <Setter Property="Foreground" Value="#0284C7"/>

        </Style>

        <!-- FILTER DROPDOWN BUTTON -->

        <Style x:Key="FilterToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">

                            <Grid>

                                <ContentPresenter Margin="14 0 36 0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>

                                <TextBlock Text="⌄"
                                           FontSize="16"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0 0 14 0"/>

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#D8B4C4"/>
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#FFF7FA"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#C88FA3"/>
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#FFF7FA"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FILTER POPUP -->

        <Style x:Key="FilterPopupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#F0E3E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.16"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX INSIDE DROPDOWN -->

        <Style x:Key="DropdownCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="Margin" Value="0 2"/>
        </Style>

        <!-- ACTIVE FILTER CHIP -->

        <Style x:Key="ChipRemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#EFD6E0"/>
            <Setter Property="Foreground" Value="#7A5563"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="8 0 0 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="11">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BUTTON -->

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18 0"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.92"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97"
                                                        ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#4F46E5"/>

        </Style>

        <!-- DANGER BUTTON -->

        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">

            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>

        </Style>

        <!-- TEXTBOX -->

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14 0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="2"/>

                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- CHECKBOX -->

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTERS -->

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}">

            <StackPanel>

      

                <!-- SEARCH + PRICE + ACTION BUTTONS -->

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="105"/>
                        <ColumnDefinition Width="105"/>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="145"/>
                    </Grid.ColumnDefinitions>

                    <!-- SEARCH -->

                    <StackPanel Grid.Column="0"
                Margin="0 0 12 0">

                        <TextBlock Text="Пошук"
                   Foreground="#6B7280"
                   FontSize="12"
                   Margin="0 0 0 6"/>

                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- MIN PRICE -->

                    <StackPanel Grid.Column="1"
                Margin="0 0 12 0">

                        <TextBlock Text="Ціна від"
                   Foreground="#6B7280"
                   FontSize="12"
                   Margin="0 0 0 6"/>

                        <TextBox Text="{Binding MinPriceText, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- MAX PRICE -->

                    <StackPanel Grid.Column="2"
                Margin="0 0 12 0">

                        <TextBlock Text="Ціна до"
                   Foreground="#6B7280"
                   FontSize="12"
                   Margin="0 0 0 6"/>

                        <TextBox Text="{Binding MaxPriceText, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <!-- STOCK -->

                    <CheckBox Grid.Column="3"
              Content="В наявності"
              IsChecked="{Binding OnlyInStock}"
              VerticalAlignment="Bottom"
              Margin="0 0 12 10"/>

                    <!-- BUTTONS -->

                    <StackPanel Grid.Column="4"
                VerticalAlignment="Bottom">

                        <Button Content="Очистити всі"
                Height="38"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0 0 0 8"
                Click="ClearFiltersButton_Click"/>

                        <Button Content="+ Додати товар"
                Height="38"
                Style="{StaticResource ModernButtonStyle}"
                Margin="0"
                Click="AddProductButton_Click"/>

                    </StackPanel>

                </Grid>
                <!-- MULTI SELECT DROPDOWNS -->

                <Grid Margin="0 16 0 0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BRAND -->

                    <StackPanel Grid.Column="0"
                                Margin="0 0 12 0">

                        <TextBlock Text="Бренд"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0 0 0 6"/>

                        <ToggleButton x:Name="BrandFilterToggle"
                                      Content="{Binding BrandSummary}"
                                      Style="{StaticResource FilterToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=BrandFilterToggle}"
                               PlacementTarget="{Binding ElementName=BrandFilterToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">

                            <Border Style="{StaticResource FilterPopupBorderStyle}"
                                    Width="240">

                                <ScrollViewer MaxHeight="230">

                                    <ItemsControl ItemsSource="{Binding Brands}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DropdownCheckBoxStyle}"/>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </StackPanel>

                    <!-- TYPE -->

                    <StackPanel Grid.Column="1"
                                Margin="0 0 12 0">

                        <TextBlock Text="Тип"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0 0 0 6"/>

                        <ToggleButton x:Name="TypeFilterToggle"
                                      Content="{Binding TypeSummary}"
                                      Style="{StaticResource FilterToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=TypeFilterToggle}"
                               PlacementTarget="{Binding ElementName=TypeFilterToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">

                            <Border Style="{StaticResource FilterPopupBorderStyle}"
                                    Width="240">

                                <ScrollViewer MaxHeight="230">

                                    <ItemsControl ItemsSource="{Binding Types}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DropdownCheckBoxStyle}"/>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </StackPanel>

                    <!-- CATEGORY -->

                    <StackPanel Grid.Column="2"
                                Margin="0 0 12 0">

                        <TextBlock Text="Категорія"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0 0 0 6"/>

                        <ToggleButton x:Name="CategoryFilterToggle"
                                      Content="{Binding CategorySummary}"
                                      Style="{StaticResource FilterToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=CategoryFilterToggle}"
                               PlacementTarget="{Binding ElementName=CategoryFilterToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">

                            <Border Style="{StaticResource FilterPopupBorderStyle}"
                                    Width="250">

                                <ScrollViewer MaxHeight="230">

                                    <ItemsControl ItemsSource="{Binding Categories}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DropdownCheckBoxStyle}"/>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </StackPanel>

                    <!-- MATERIAL -->

                    <StackPanel Grid.Column="3"
                                Margin="0 0 12 0">

                        <TextBlock Text="Матеріал"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0 0 0 6"/>

                        <ToggleButton x:Name="MaterialFilterToggle"
                                      Content="{Binding MaterialSummary}"
                                      Style="{StaticResource FilterToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=MaterialFilterToggle}"
                               PlacementTarget="{Binding ElementName=MaterialFilterToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">

                            <Border Style="{StaticResource FilterPopupBorderStyle}"
                                    Width="240">

                                <ScrollViewer MaxHeight="230">

                                    <ItemsControl ItemsSource="{Binding Materials}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DropdownCheckBoxStyle}"/>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </StackPanel>

                    <!-- COLOR -->

                    <StackPanel Grid.Column="4">

                        <TextBlock Text="Колір"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   Margin="0 0 0 6"/>

                        <ToggleButton x:Name="ColorFilterToggle"
                                      Content="{Binding ColorSummary}"
                                      Style="{StaticResource FilterToggleButtonStyle}"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=ColorFilterToggle}"
                               PlacementTarget="{Binding ElementName=ColorFilterToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">

                            <Border Style="{StaticResource FilterPopupBorderStyle}"
                                    Width="240">

                                <ScrollViewer MaxHeight="230">

                                    <ItemsControl ItemsSource="{Binding Colors}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DropdownCheckBoxStyle}"/>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </StackPanel>

                </Grid>

                <!-- ACTIVE FILTER CHIPS -->

                <ItemsControl ItemsSource="{Binding ActiveFilterChips}"
                              Margin="0 18 0 0">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#FFF7FA"
                                    BorderBrush="#F0D5E1"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="12 6"
                                    Margin="0 0 8 8">

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock Text="{Binding Label}"
                                               Foreground="#7A5563"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <Button Content="×"
                                            Tag="{Binding}"
                                            Style="{StaticResource ChipRemoveButtonStyle}"
                                            Click="RemoveFilterChipButton_Click"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </Border>

        <!-- PRODUCT CARDS -->

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <ItemsControl ItemsSource="{Binding ProductsView}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Style="{StaticResource ProductCardStyle}">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- PHOTO -->

                                    <Button Grid.Row="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="0"
                                            Tag="{Binding}"
                                            Click="ProductImageButton_Click">

                                        <Border Style="{StaticResource ProductImageBorderStyle}">

                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill"/>

                                        </Border>

                                    </Button>

                                    <!-- TITLE -->

                                    <StackPanel Grid.Row="1"
                                                Margin="0 0 0 12">

                                        <TextBlock Text="{Binding ModelName}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#111827"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="48"/>

                                        <TextBlock Text="{Binding BrandName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#5B8DEF"
                                                   Margin="0 4 0 0"/>

                                    </StackPanel>

                                    <!-- MAIN INFO -->

                                    <Grid Grid.Row="2"
                                          Margin="0 0 0 12">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- TYPE -->

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0 0 10 10">

                                            <TextBlock Text="Тип"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <TextBlock Text="{Binding TypeName}"
                                                       Style="{StaticResource ProductInfoValueStyle}"/>

                                        </StackPanel>

                                        <!-- COLOR -->

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0 0 0 10">

                                            <TextBlock Text="Колір"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <TextBlock Text="{Binding ColorName}"
                                                       Style="{StaticResource ProductInfoValueStyle}"/>

                                        </StackPanel>

                                        <!-- MATERIAL -->

                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0 0 10 10">

                                            <TextBlock Text="Матеріал"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <TextBlock Text="{Binding MaterialName}"
                                                       Style="{StaticResource ProductInfoValueStyle}"/>

                                        </StackPanel>

                                        <!-- CATEGORY -->

                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0 0 0 10">

                                            <TextBlock Text="Категорія"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <TextBlock Text="{Binding CategoryName}"
                                                       Style="{StaticResource ProductInfoValueStyle}"
                                                       MaxHeight="36"/>

                                        </StackPanel>

                                        <!-- DATE -->

                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0 0 10 0">

                                            <TextBlock Text="Дата"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <TextBlock Text="{Binding ArrivalDate, StringFormat={}{0:dd.MM.yyyy}}"
                                                       Style="{StaticResource ProductInfoValueStyle}"/>

                                        </StackPanel>

                                        <!-- QUANTITY -->

                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="1">

                                            <TextBlock Text="Кількість"
                                                       Style="{StaticResource ProductInfoLabelStyle}"/>

                                            <Border Style="{StaticResource QuantityBadgeStyle}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0 3 0 0">

                                                <TextBlock Text="{Binding Quantity, StringFormat={}{0} шт.}"
                                                           Style="{StaticResource QuantityBadgeTextStyle}"/>

                                            </Border>

                                        </StackPanel>

                                    </Grid>

                                    <!-- PRICE -->

                                    <Border Grid.Row="3"
                                            Background="#F9FAFB"
                                            CornerRadius="18"
                                            Padding="12"
                                            Margin="0 0 0 14"
                                            VerticalAlignment="Bottom">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">

                                                <TextBlock Text="Ціна"
                                                           FontSize="12"
                                                           Foreground="#6B7280"/>

                                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2} грн}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="#111827"/>

                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right">

                                                <TextBlock Text="Сума"
                                                           FontSize="12"
                                                           Foreground="#6B7280"
                                                           HorizontalAlignment="Right"/>

                                                <TextBlock Text="{Binding TotalValue, StringFormat={}{0:N2} грн}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#15803D"
                                                           HorizontalAlignment="Right"/>

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                    <!-- ACTIONS -->

                                    <StackPanel Grid.Row="4"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <!-- Додати варіант -->

                                        <Button Content="&#xE710;"
                                                ToolTip="Додати варіант"
                                                Tag="{Binding}"
                                                Style="{StaticResource TableVariantButtonStyle}"
                                                Click="RowAddVariantButton_Click"/>

                                        <!-- Редагувати -->

                                        <Button Content="&#xE70F;"
                                                ToolTip="Редагувати"
                                                Tag="{Binding}"
                                                Style="{StaticResource TableEditButtonStyle}"
                                                Click="RowEditProductButton_Click"/>

                                        <!-- Видалити -->

                                        <Button Content="&#xE74D;"
                                                ToolTip="Видалити"
                                                Tag="{Binding}"
                                                Style="{StaticResource TableDeleteButtonStyle}"
                                                Click="RowDeleteProductButton_Click"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Border>

    </Grid>

</UserControl>