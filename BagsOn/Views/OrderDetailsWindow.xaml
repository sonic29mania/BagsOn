<Window x:Class="BagsOn.Views.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:BagsOn.Converters"
        Title="Деталі замовлення"
        Height="760"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6FC">

    <Window.Resources>
        <conv:ImagePathConverter x:Key="ImagePathConverter"/>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="46"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- HEADER -->

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock x:Name="OrderTitleTextBlock"
                               Text="Замовлення №"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    <TextBlock x:Name="OrderDateTextBlock"
                               Text="Дата замовлення"
                               FontSize="14"
                               Foreground="#6B7280"
                               Margin="0 6 0 0"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Background="#DBEAFE"
                        CornerRadius="14"
                        Padding="14 7"
                        VerticalAlignment="Center">

                    <TextBlock x:Name="StatusTextBlock"
                               Text="Статус"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1D4ED8"/>

                </Border>

            </Grid>

        </Border>


        <!-- CONTENT -->

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <!-- CUSTOMER + DELIVERY -->

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <!-- CUSTOMER -->

                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Margin="0 0 8 16">

                        <StackPanel>

                            <TextBlock Text="Клієнт"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0 0 0 16"/>

                            <TextBlock Text="Ім’я"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="CustomerNameTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Телефон"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="PhoneTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Email"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="EmailTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Місто"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="CityTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                        </StackPanel>

                    </Border>


                    <!-- DELIVERY -->

                    <Border Grid.Column="1"
                            Style="{StaticResource CardStyle}"
                            Margin="8 0 0 16">

                        <StackPanel>

                            <TextBlock Text="Доставка"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0 0 0 16"/>

                            <TextBlock Text="Тип доставки"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="DeliveryTypeTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Дата доставки"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="DeliveryDateTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Час доставки"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="DeliveryTimeTextBlock"
                                       Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Text="Адреса доставки"
                                       Style="{StaticResource LabelTextStyle}"/>

                            <TextBlock x:Name="DeliveryAddressTextBlock"
                                       Style="{StaticResource ValueTextStyle}"
                                       TextWrapping="Wrap"/>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- ARCHIVE INFO -->

                <Border x:Name="ArchiveInfoBorder"
        Background="#FFF7ED"
        CornerRadius="18"
        Padding="18"
        Margin="0 18 0 18"
        Visibility="Collapsed">

                    <StackPanel>

                        <TextBlock Text="Архівна інформація"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#9A3412"
                   Margin="0 0 0 12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                        Margin="0 0 16 0">
                                <TextBlock Text="Тип архіву"
                           FontSize="12"
                           Foreground="#9CA3AF"
                           Margin="0 0 0 4"/>

                                <TextBlock x:Name="ArchiveTypeTextBlock"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                        Margin="0 0 16 0">
                                <TextBlock Text="Дата архівації"
                           FontSize="12"
                           Foreground="#9CA3AF"
                           Margin="0 0 0 4"/>

                                <TextBlock x:Name="ArchiveDateTextBlock"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Причина"
                           FontSize="12"
                           Foreground="#9CA3AF"
                           Margin="0 0 0 4"/>

                                <TextBlock x:Name="ArchiveReasonTextBlock"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>

                </Border>
                <!-- ORDER ITEMS -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Товари в замовленні"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0 0 0 16"/>

                        <DataGrid x:Name="OrderItemsDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeaderWidth="0"
                                  Height="220">

                            <DataGrid.Columns>

                                <!-- Фото товару -->

                                <DataGridTemplateColumn Header="Фото"
                            Width="80">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>

                                            <Border Width="54"
                        Height="54"
                        CornerRadius="12"
                        Background="#F3F4F6"
                        ClipToBounds="True"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                                                <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="UniformToFill"/>

                                            </Border>

                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>


                                <DataGridTextColumn Header="Модель"
                        Binding="{Binding ModelName}"
                        Width="*"/>

                                <DataGridTextColumn Header="Бренд"
                        Binding="{Binding BrandName}"
                        Width="120"/>

                                <DataGridTextColumn Header="Колір"
                        Binding="{Binding ColorName}"
                        Width="100"/>

                                <DataGridTextColumn Header="К-сть"
                        Binding="{Binding Quantity}"
                        Width="70"/>

                                <DataGridTextColumn Header="Ціна"
                        Binding="{Binding UnitPrice, StringFormat={}{0:N2} грн}"
                        Width="130"/>

                                <DataGridTextColumn Header="Знижка"
                        Binding="{Binding DiscountPercent, StringFormat={}{0:N0}%}"
                        Width="90"/>

                                <DataGridTextColumn Header="Сума"
                        Binding="{Binding LineTotal, StringFormat={}{0:N2} грн}"
                        Width="140"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>


                <!-- COMMENT -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Коментар"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0 0 0 12"/>

                        <TextBlock x:Name="CommentTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   FontSize="14"/>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>


        <!-- FOOTER -->

        <!-- FOOTER -->

        <Border Grid.Row="2"
        Background="White"
        CornerRadius="22"
        Padding="18"
        Margin="0 16 0 0">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                          ShadowDepth="0"
                          Opacity="0.08"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <TextBlock Text="Разом:"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111827"
                       Margin="0 0 8 0"/>

                    <TextBlock x:Name="TotalAmountTextBlock"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#15803D"/>

                </StackPanel>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal">

                    <Button Content="🖨 Друк чеку"
                    Width="130"
                    Height="40"
                    Background="#EEF2FF"
                    Foreground="#4F46E5"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Margin="0 0 10 0"
                    Click="PrintReceiptButton_Click"/>

                    <Button Content="📄 Експорт PDF"
                    Width="140"
                    Height="40"
                    Background="#DCFCE7"
                    Foreground="#15803D"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Margin="0 0 10 0"
                    Click="ExportPdfButton_Click"/>

                    <Button Content="Закрити"
                    Width="110"
                    Height="40"
                    Background="#F3F4F6"
                    Foreground="#374151"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="CloseButton_Click"/>

                </StackPanel>

            </Grid>

        </Border>
    </Grid>
</Window>